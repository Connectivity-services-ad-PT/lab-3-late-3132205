			"name": "05_Consumer-side Smoke",
			"item": [
				{
					"name": "Call IoT Dependency Mock",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"IoT Ingestion dependency mock server is alive\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{iotMockUrl}}/health",
							"host": [
								"{{iotMockUrl}}"
							],
							"path": [
								"health"
							]
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "06_Local-only NonFunctional",
			"item": [
				{
					"name": "Check Latency SLA",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.environment.get(\"env\") === \"local\") {",
									"    pm.test(\"AI Model initialization latency is within SLA (< 1500ms)\", function () {",
									"        pm.expect(pm.response.responseTime).to.be.below(1500);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"health"
							]
						}
					],
					"response": []
				}
			]
		},
