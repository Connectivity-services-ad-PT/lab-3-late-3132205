{
	"info": {
		"name": "team_vision",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01_Functional",
			"item": [
				{
					"name": "Analyze Image Success",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response returns analysis results\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"analysis_id\");",
									"    pm.expect(json.predictions).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"camera_id\": \"CAM-GATE-01\",\n  \"image_url\": \"https://smart-campus.local/storage/frames/frame_001.jpg\",\n  \"target_type\": \"face\",\n  \"min_confidence\": 0.5\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						],
						"url": {
							"raw": "{{baseUrl}}/ai/analyze",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"ai",
								"analyze"
							]
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "02_Auth",
			"item": [
				{
					"name": "Analyze Image Missing Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Unauthorized request must return 401\", function () {",
									"    pm.expect([401, 403]).to.include(pm.response.code);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"camera_id\": \"CAM-GATE-01\",\n  \"image_url\": \"https://smart-campus.local/storage/frames/frame_001.jpg\",\n  \"target_type\": \"face\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						],
						"url": {
							"raw": "{{baseUrl}}/ai/analyze",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"ai",
								"analyze"
							]
