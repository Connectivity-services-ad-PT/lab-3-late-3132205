				}
			]
		},
		{
			"name": "03_Negative",
			"item": [
				{
					"name": "Analyze Image Invalid Payload",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Invalid payload returns 400 Bad Request\", function () {",
									"    pm.expect([400, 422]).to.include(pm.response.code);",
									"});",
									"",
									"pm.test(\"Error matches ProblemDetails RFC 7807\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"title\");",
									"    pm.expect(json.status).to.be.within(400, 599);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"camera_id\": \"\",\n  \"target_type\": \"unknown_type\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						],
						"url": {
							"raw": "{{baseUrl}}/ai/analyze",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"ai",
								"analyze"
							]
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "04_Boundary_Reliability",
			"item": [
				{
					"name": "Analyze Image Confidence Out Of Boundary",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Out of range min_confidence is rejected\", function () {",
									"    pm.expect([400, 422]).to.include(pm.response.code);",
									"    const json = pm.response.json();",
									"    pm.expect(json.detail).to.include(\"min_confidence\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"camera_id\": \"CAM-GATE-01\",\n  \"image_url\": \"https://smart-campus.local/storage/frames/frame_001.jpg\",\n  \"target_type\": \"face\",\n  \"min_confidence\": 1.5\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						],
						"url": {
							"raw": "{{baseUrl}}/ai/analyze",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"ai",
								"analyze"
							]
						}
					],
					"response": []
				}
			]
		},
